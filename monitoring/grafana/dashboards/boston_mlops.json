{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "title": "Boston Housing MLOps Dashboard",
  "uid": "boston-mlops-001",
  "description": "Live monitoring of MLOps pipeline — RMSE, R2, dataset drift, pipeline runs",
  "tags": ["mlops", "boston", "drift"],
  "refresh": "10s",
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "RMSE over Time — Linear Regression",
      "description": "Root Mean Square Error of Linear Regression. Spikes = drift detected.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_model_rmse{model_type=\"linear_regression\"}",
          "legendFormat": "Linear Regression RMSE",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "always",
            "pointSize": 6
          },
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 7 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "title": "RMSE over Time — Random Forest",
      "description": "Root Mean Square Error of Random Forest. Lower is better.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_model_rmse{model_type=\"random_forest\"}",
          "legendFormat": "Random Forest RMSE",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "always",
            "pointSize": 6
          },
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 4 },
              { "color": "red",    "value": 6 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "title": "R² Score over Time — Both Models",
      "description": "R-squared score. Higher is better. Drop = model degraded due to drift.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_model_r2{model_type=\"linear_regression\"}",
          "legendFormat": "Linear Regression R²",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_model_r2{model_type=\"random_forest\"}",
          "legendFormat": "Random Forest R²",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "always",
            "pointSize": 6
          },
          "unit": "none",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 4,
      "title": "Dataset LSTAT Mean — Drift Indicator",
      "description": "Mean of LSTAT feature. Sudden jump = drift was injected by Airflow.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_dataset_lstat_mean",
          "legendFormat": "LSTAT mean",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_dataset_rm_mean",
          "legendFormat": "RM mean",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "always",
            "pointSize": 5
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 20 },
              { "color": "red",    "value": 28 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 5,
      "title": "MAE over Time — Both Models",
      "description": "Mean Absolute Error for both models over time.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_model_mae{model_type=\"linear_regression\"}",
          "legendFormat": "Linear Regression MAE",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_model_mae{model_type=\"random_forest\"}",
          "legendFormat": "Random Forest MAE",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8, "showPoints": "always" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "title": "Dataset MEDV Mean (Target)",
      "description": "Mean of the target variable (house price). Shifts after drift injection.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_dataset_medv_mean",
          "legendFormat": "MEDV mean",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "title": "Current RF RMSE",
      "description": "Current RMSE of Random Forest. Red = drift detected.",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 24, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_model_rmse{model_type=\"random_forest\"}",
          "legendFormat": "RF RMSE",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 20,
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 8 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true }
    },
    {
      "id": 8,
      "title": "Current RF R²",
      "description": "Current R² of Random Forest. Green = healthy. Red = degraded.",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 24, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_model_r2{model_type=\"random_forest\"}",
          "legendFormat": "RF R²",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "green",  "value": 0.8 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true }
    },
    {
      "id": 9,
      "title": "Current LR RMSE",
      "description": "Current RMSE of Linear Regression.",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 24, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_model_rmse{model_type=\"linear_regression\"}",
          "legendFormat": "LR RMSE",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 20,
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 6 },
              { "color": "red",    "value": 9 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true }
    },
    {
      "id": 10,
      "title": "Current LR R²",
      "description": "Current R² of Linear Regression.",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 24, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_model_r2{model_type=\"linear_regression\"}",
          "legendFormat": "LR R²",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.55 },
              { "color": "green",  "value": 0.72 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": true }
    },
    {
      "id": 11,
      "title": "Dataset Row Count",
      "type": "stat",
      "gridPos": { "x": 0, "y": 30, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_dataset_n_rows",
          "legendFormat": "Rows",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" }
    },
    {
      "id": 12,
      "title": "Total Pipeline Runs",
      "type": "stat",
      "gridPos": { "x": 6, "y": 30, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_pipeline_runs_total",
          "legendFormat": "Runs",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" }
    },
    {
      "id": 13,
      "title": "Drift Detections Total",
      "type": "stat",
      "gridPos": { "x": 12, "y": 30, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_drift_detections_total",
          "legendFormat": "Drift Events",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 3 }
          ]}
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" }
    },
    {
      "id": 14,
      "title": "Dataset LSTAT Mean (Current)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 30, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "boston_dataset_lstat_mean",
          "legendFormat": "LSTAT mean",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green",  "value": null },
            { "color": "orange", "value": 20 },
            { "color": "red",    "value": 28 }
          ]}
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Datasource"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Pipeline Runs",
        "enable": true,
        "iconColor": "purple",
        "datasource": { "type": "prometheus" },
        "expr": "changes(boston_pipeline_runs_total[1m]) > 0",
        "step": "60s",
        "titleFormat": "Pipeline Run",
        "textFormat": "New training run triggered"
      }
    ]
  }
}
